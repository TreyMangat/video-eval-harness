# === Video Eval Harness Configuration ===

# OpenRouter API key (primary provider - recommended)
# One key gives access to GPT-4o, Gemini, Claude, Qwen, Llama, etc.
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Native provider keys (for direct API access)
# Only needed if you configure models with provider: openai or provider: gemini
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# Artifacts directory (default: ./artifacts)
# VBENCH_ARTIFACTS_DIR=./artifacts

# Log level (DEBUG, INFO, WARNING, ERROR)
# VBENCH_LOG_LEVEL=INFO

# Max concurrent model requests
# VBENCH_MAX_CONCURRENCY=4

# FFmpeg path (if not on PATH, auto-discovery will be attempted on Windows)
# FFMPEG_PATH=ffmpeg
